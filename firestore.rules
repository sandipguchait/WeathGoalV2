rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidFinancialProfile(data) {
      return data.keys().hasAll(['userId', 'goalDate', 'categories', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.goalDate is string
        && data.categories is map
        && data.updatedAt == request.time;
    }

    function isValidIncomeRecord(data) {
      return data.keys().hasAll(['userId', 'amount', 'month', 'year', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.amount is number
        && data.month is number && data.month >= 1 && data.month <= 12
        && data.year is number
        && data.updatedAt == request.time;
    }

    match /profiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidFinancialProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidFinancialProfile(request.resource.data);
      allow delete: if false; 
    }

    match /income_records/{recordId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidIncomeRecord(request.resource.data);
      allow update: if isSignedIn() && isValidIncomeRecord(request.resource.data);
      allow delete: if false;
    }
  }
}
